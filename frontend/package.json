{
  "name": "sandtable-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:theatre-assets": "node ../scripts/sync-theatre-assets.mjs",
    "predev": "npm run sync:theatre-assets",
    "dev": "vite --config vite.config.js --host 127.0.0.1 --port 3000",
    "prebuild": "npm run sync:theatre-assets",
    "build": "tsc && vite build --config vite.config.js",
    "prepreview": "npm run sync:theatre-assets",
    "preview": "vite preview --config vite.config.js --host 127.0.0.1 --port 3000",
    "test:phase1": "playwright test e2e/phase1.spec.ts",
    "test:phase1:update": "playwright test e2e/phase1.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "pixi.js": "^8.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5"
  }
}
