              "unitSelector": "unit",
              "stat": "Attack",
              "amount": 1,
              "description": "{unit.name} gains +1 attack."
            },
            {
              "effectType": "modifyUnitStat",
              "unitSelector": "unit",
              "stat": "Supply",
              "amount": -2,
              "description": "{unit.name} loses 2 supply."
            },
            {
              "effectType": "addCampaignModifier",
              "modifierId": "armour-tempo",
              "name": "Armour Tempo",
              "durationTurns": 1,
              "values": {
                "attack": 1,
                "supplyRisk": 2
