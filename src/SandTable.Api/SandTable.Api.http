@SandTable.Api_HostAddress = http://localhost:5171
@CampaignUid = 00000000-0000-0000-0000-000000000000
@TensionCardId = overextended-armour

GET {{SandTable.Api_HostAddress}}/api/health
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/content/theatres
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/content/theatres/north-africa
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/content/theatres/north-africa/scenarios/north-africa-1942
Accept: application/json

###

POST {{SandTable.Api_HostAddress}}/api/campaigns
Content-Type: application/json

{
  "name": "Development North Africa Campaign",
  "theatreId": "north-africa",
  "scenarioId": "north-africa-1942",
  "playerSide": "Axis"
}

###

GET {{SandTable.Api_HostAddress}}/api/campaigns
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/snapshot
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/state
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/events?order=Chronological
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/events?order=LatestTurnFirst&limit=50
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/timeline
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/turns
Accept: application/json

###

GET {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/turns/1
Accept: application/json

###

POST {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/commands
Content-Type: application/json

{
  "commands": [
    {
      "sequence": 1,
      "command": {
        "commandType": "Move",
        "unitId": "15th-panzer",
        "fromRegionId": "tripoli",
        "pathRegionIds": ["benghazi"]
      }
    }
  ]
}

###

POST {{SandTable.Api_HostAddress}}/api/campaigns/{{CampaignUid}}/resolve-turn
Accept: application/json

###

